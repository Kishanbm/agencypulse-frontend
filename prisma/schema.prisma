// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum Role {
  SUPER_ADMIN
  STAFF
  CLIENT
  VIEWER
}

enum IntegrationType {
  GOOGLE_ANALYTICS
  GOOGLE_ADS
  META_ADS
  SEARCH_CONSOLE
}

enum SyncStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model Agency {
  id                  String   @id @default(uuid())
  name                String
  logoUrl             String?
  primaryColour       String   @default("#1A56A0")
  accentColour        String   @default("#FBBF24")
  customDomain        String?  @unique
  faviconUrl          String?
  reportFooterText    String?
  removeAgencyBranding Boolean  @default(false)
  planId              String?
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  users               User[]
  clients             Client[]
  campaigns           Campaign[]
  auditLogs           AuditLog[]

  @@map("agencies")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  name          String
  role          Role     @default(STAFF)
  agencyId      String   @map("agency_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  agency        Agency   @relation(fields: [agencyId], references: [id])
  assignedCampaigns CampaignStaff[]

  @@index([agencyId])
  @@map("users")
}

model Client {
  id            String   @id @default(uuid())
  name          String
  agencyId      String   @map("agency_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  agency        Agency   @relation(fields: [agencyId], references: [id])
  campaigns     Campaign[]

  @@index([agencyId])
  @@map("clients")
}

model Campaign {
  id            String   @id @default(uuid())
  name          String
  websiteUrl    String?  @map("website_url")
  timezone      String   @default("UTC")
  clientId      String   @map("client_id")
  agencyId      String   @map("agency_id")
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  client        Client   @relation(fields: [clientId], references: [id])
  agency        Agency   @relation(fields: [agencyId], references: [id])
  integrations  Integration[]
  dashboards    Dashboard[]
  reports       Report[]
  staff         CampaignStaff[]

  @@index([clientId])
  @@index([agencyId])
  @@map("campaigns")
}

model CampaignStaff {
  campaignId    String   @map("campaign_id")
  userId        String   @map("user_id")

  campaign      Campaign @relation(fields: [campaignId], references: [id])
  user          User     @relation(fields: [userId], references: [id])

  @@id([campaignId, userId])
  @@map("campaign_staff")
}

model Integration {
  id                String          @id @default(uuid())
  type              IntegrationType
  encryptedToken    String          @map("encrypted_token")
  tokenExpiry       DateTime?       @map("token_expiry")
  syncStatus        SyncStatus      @default(PENDING) @map("sync_status")
  campaignId        String          @map("campaign_id")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  campaign          Campaign        @relation(fields: [campaignId], references: [id])
  dataSyncs         DataSync[]
  metricSnapshots   MetricSnapshot[]

  @@index([campaignId])
  @@map("integrations")
}

model DataSync {
  id                String     @id @default(uuid())
  status            SyncStatus
  error             String?
  integrationId     String     @map("integration_id")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  integration       Integration @relation(fields: [integrationId], references: [id])

  @@index([integrationId])
  @@map("data_syncs")
}

model MetricSnapshot {
  id                String   @id @default(uuid())
  date              DateTime
  metricKey         String   @map("metric_key")
  metricValue       Float    @map("metric_value")
  integrationId     String   @map("integration_id")
  createdAt         DateTime @default(now()) @map("created_at")

  integration       Integration @relation(fields: [integrationId], references: [id])

  @@index([integrationId])
  @@index([date])
  @@index([metricKey])
  @@map("metric_snapshots")
}

model Dashboard {
  id            String   @id @default(uuid())
  name          String
  isDefault     Boolean  @default(false) @map("is_default")
  campaignId    String   @map("campaign_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  campaign      Campaign @relation(fields: [campaignId], references: [id])
  widgets       Widget[]

  @@index([campaignId])
  @@map("dashboards")
}

model Widget {
  id            String   @id @default(uuid())
  type          String
  config        Json
  x             Int
  y             Int
  w             Int
  h             Int
  dashboardId   String   @map("dashboard_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  dashboard     Dashboard @relation(fields: [dashboardId], references: [id])

  @@index([dashboardId])
  @@map("widgets")
}

model Report {
  id            String   @id @default(uuid())
  name          String
  config        Json
  pdfUrl        String?  @map("pdf_url")
  campaignId    String   @map("campaign_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  campaign      Campaign @relation(fields: [campaignId], references: [id])
  schedules     ReportSchedule[]

  @@index([campaignId])
  @@map("reports")
}

model ReportSchedule {
  id            String   @id @default(uuid())
  frequency     String
  recipients    String   // Comma-separated or JSON string for SQLite compatibility
  nextSendAt    DateTime @map("next_send_at")
  lastSentAt    DateTime? @map("last_sent_at")
  reportId      String   @map("report_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  report        Report   @relation(fields: [reportId], references: [id])

  @@index([reportId])
  @@map("report_schedules")
}

model AuditLog {
  id            String   @id @default(uuid())
  action        String
  resourceType  String   @map("resource_type")
  resourceId    String   @map("resource_id")
  userId        String   @map("user_id")
  agencyId      String   @map("agency_id")
  createdAt     DateTime @default(now()) @map("created_at")

  agency        Agency   @relation(fields: [agencyId], references: [id])

  @@index([agencyId])
  @@index([userId])
  @@map("audit_logs")
}
